# Copy this file to .env (same folder) and fill in your own values.
# .env is gitignored -- never commit your real key.

# Required. Get one at https://aistudio.google.com
GEMINI_API_KEY=

# Optional. Model used by Scout, the video curator, and the voice judge.
# Run check_setup.py to see which models your key can call. Defaults to Flash.
GEMINI_MODEL=gemini-2.5-flash

# Optional. Model used by the Viral agent for drafting, since draft quality
# matters most there. Defaults to a pro-tier model.
GEMINI_WRITER_MODEL=gemini-pro-latest

# --- LinkedIn auto-posting (used by the Viral and Video agents) ---
# The agents can auto-post to the Metis LinkedIn page. They DEFAULT TO DRY RUN:
# nothing is posted until you set LINKEDIN_DRY_RUN=false. Getting a token is a
# one-time manual step (LinkedIn developer app + "Community Management API"
# product for the organization page + OAuth). See README.
LINKEDIN_ACCESS_TOKEN=
# Who the post is authored as. For the Metis page (an organization):
#   urn:li:organization:xxxx
# (A personal profile would be urn:li:person:xxxx.)
LINKEDIN_ACTOR_URN=
# Leave true until you have a real token and want posts to go live.
LINKEDIN_DRY_RUN=true
# Optional. LinkedIn versioned-API month, YYYYMM. Defaults to a recent version.
LINKEDIN_API_VERSION=202405
