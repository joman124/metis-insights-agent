# Copy this file to .env (same folder) and fill in your own values.
# .env is gitignored -- never commit your real key.

# Required. Get one at https://aistudio.google.com
# For Metis, reuse the same key already configured for the After Work /
# kaggle-agent-capstone project -- no separate key is needed.
GEMINI_API_KEY=

# Optional. Model used by Scout, the Strategist's helpers, and the voice
# judge. Run check_setup.py to see which models your key can call. If unset,
# defaults to a current Flash model.
GEMINI_MODEL=gemini-2.5-flash

# Optional. Model used only by the essay / field-note writers, since draft
# quality matters most there. Defaults to a pro-tier model even though
# GEMINI_MODEL defaults to Flash. If your key cannot call gemini-2.5-pro,
# run check_setup.py and set this to a pro model that is available to you.
GEMINI_WRITER_MODEL=gemini-2.5-pro

# Optional. Path to your local checkout of the metis-website repo. When set
# (or when ../metis-website exists), content_publisher.promote_to_site()
# writes content/insights-data.json and the generated article page straight
# into that checkout for you to review and commit. If it cannot find the
# site, it falls back to writing into ./site_output/ instead.
METIS_SITE_DIR=../metis-website
